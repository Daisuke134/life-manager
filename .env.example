# Life Manager — copy to .env (gitignored) and fill. Or set these in your OpenClaw/host env.
# The repo is self-contained: it reads config ONLY from here (or LIFE_ENV_FILE / process.env).

# ── Who & where (profile) ──────────────────────────────────────────────
LIFE_GOOGLE_ACCOUNT=you@gmail.com      # Google account whose calendar/gmail to manage
LIFE_OWNER_EMAIL=you@gmail.com         # where approval emails go (defaults to the Google account)
LIFE_HOME_ADDRESS=                     # your home address (used for "at home" routine events + travel origin)
LIFE_PHONE=+10000000000                # your phone in E.164 — Anicca calls this number
LIFE_CAL_ID=primary                    # calendar id (default: primary)

# ── Data + executor (paths/bins) ───────────────────────────────────────
# LIFE_DATA_DIR=~/.life-manager        # where state lives (default ~/.life-manager). NOT required.
# GOG_BIN=gog                          # gog CLI on PATH (local calendar/gmail transport)
# LIFE_SCHEDULER_BIN=openclaw          # the executor that runs the scheduled calls
# CLOUDFLARED_BIN=cloudflared          # tunnel for the call bridge

# ── Local calendar/gmail transport (gog) ───────────────────────────────
GOG_ACCOUNT=you@gmail.com
GOG_KEYRING_PASSWORD=
GOOGLE_API_KEY=                        # Google Maps Geocoding + Directions (travel times)

# ── Phone call (Telnyx + Gemini Live, voice = Charon) ──────────────────
TELNYX_API_KEY=
TELNYX_CONNECTION_ID=
TELNYX_FROM=
GEMINI_API_KEY=
